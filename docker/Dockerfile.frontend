FROM node:20-alpine

WORKDIR /app

# Copy package files
COPY frontend/package.json frontend/package-lock.json* ./

# Install dependencies
RUN npm install

# Copy application files
COPY frontend .

# Expose port
EXPOSE 5173

# Default command (--host needed so Vite listens on 0.0.0.0 inside Docker)
CMD ["npm", "run", "dev", "--", "--host"]
