APP_NAME="Fenix Educacao"
APP_ENV=local
APP_DEBUG=true
APP_KEY=base64:YOUR_APP_KEY_HERE
APP_URL=http://localhost:8885

# Database
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=fenix_db
DB_USERNAME=fenix_user
DB_PASSWORD=fenix_password

# Redis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
CACHE_DRIVER=redis
SESSION_DRIVER=redis

# Frontend
VITE_API_URL=http://localhost:8000/api

# Queue
QUEUE_CONNECTION=sync
