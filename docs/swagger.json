{
    "openapi": "3.0.0",
    "info": {
        "title": "Fenix Educação API",
        "version": "1.0.0",
        "description": "Plataforma de Provas Online - API REST"
    },
    "servers": [
        {
            "url": "http://localhost:8885/api/v1",
            "description": "API Server"
        }
    ],
    "paths": {
        "/health": {
            "get": {
                "tags": ["Health"],
                "summary": "Verificar saúde da API",
                "responses": {
                    "200": {
                        "description": "API está saudável",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/auth/register": {
            "post": {
                "tags": ["Auth"],
                "summary": "Registrar novo usuário",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "name": {"type": "string"},
                                    "email": {"type": "string"},
                                    "password": {"type": "string"},
                                    "password_confirmation": {"type": "string"},
                                    "role": {"type": "string", "enum": ["professor", "student"]}
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {"description": "Usuário criado com sucesso"}
                }
            }
        },
        "/auth/login": {
            "post": {
                "tags": ["Auth"],
                "summary": "Login de usuário",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "email": {"type": "string"},
                                    "password": {"type": "string"}
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "200": {"description": "Login bem-sucedido"},
                    "401": {"description": "Credenciais inválidas"}
                }
            }
        },
        "/auth/logout": {
            "post": {
                "tags": ["Auth"],
                "summary": "Logout de usuário",
                "security": [{"bearerAuth": []}],
                "responses": {
                    "200": {"description": "Logout realizado"}
                }
            }
        },
        "/auth/me": {
            "get": {
                "tags": ["Auth"],
                "summary": "Obter dados do usuário logado",
                "security": [{"bearerAuth": []}],
                "responses": {
                    "200": {"description": "Dados do usuário"}
                }
            }
        },
        "/exams": {
            "get": {
                "tags": ["Exams"],
                "summary": "Listar provas",
                "security": [{"bearerAuth": []}],
                "responses": {
                    "200": {"description": "Lista de provas"}
                }
            },
            "post": {
                "tags": ["Exams"],
                "summary": "Criar nova prova",
                "security": [{"bearerAuth": []}],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "title": {"type": "string"},
                                    "description": {"type": "string"},
                                    "passing_grade": {"type": "integer"}
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {"description": "Prova criada"}
                }
            }
        },
        "/exams/{id}": {
            "get": {
                "tags": ["Exams"],
                "summary": "Ver detalhes de uma prova",
                "security": [{"bearerAuth": []}],
                "parameters": [
                    {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
                ],
                "responses": {
                    "200": {"description": "Detalhes da prova"}
                }
            },
            "put": {
                "tags": ["Exams"],
                "summary": "Atualizar prova",
                "security": [{"bearerAuth": []}],
                "parameters": [
                    {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
                ],
                "responses": {
                    "200": {"description": "Prova atualizada"}
                }
            },
            "delete": {
                "tags": ["Exams"],
                "summary": "Deletar prova",
                "security": [{"bearerAuth": []}],
                "parameters": [
                    {"name": "id", "in": "path", "required": true, "schema": {"type": "integer"}}
                ],
                "responses": {
                    "204": {"description": "Prova deletada"}
                }
            }
        },
        "/exams/{exam}/questions": {
            "get": {
                "tags": ["Questions"],
                "summary": "Listar questões de uma prova",
                "security": [{"bearerAuth": []}],
                "parameters": [
                    {"name": "exam", "in": "path", "required": true, "schema": {"type": "integer"}}
                ],
                "responses": {
                    "200": {"description": "Lista de questões"}
                }
            },
            "post": {
                "tags": ["Questions"],
                "summary": "Criar questão",
                "security": [{"bearerAuth": []}],
                "parameters": [
                    {"name": "exam", "in": "path", "required": true, "schema": {"type": "integer"}}
                ],
                "responses": {
                    "201": {"description": "Questão criada"}
                }
            }
        },
        "/questions/{question}": {
            "put": {
                "tags": ["Questions"],
                "summary": "Atualizar questão",
                "security": [{"bearerAuth": []}],
                "parameters": [
                    {"name": "question", "in": "path", "required": true, "schema": {"type": "integer"}}
                ],
                "responses": {
                    "200": {"description": "Questão atualizada"}
                }
            },
            "delete": {
                "tags": ["Questions"],
                "summary": "Deletar questão",
                "security": [{"bearerAuth": []}],
                "parameters": [
                    {"name": "question", "in": "path", "required": true, "schema": {"type": "integer"}}
                ],
                "responses": {
                    "204": {"description": "Questão deletada"}
                }
            }
        },
        "/submissions/submit": {
            "post": {
                "tags": ["Submissions"],
                "summary": "Submeter respostas de uma prova",
                "security": [{"bearerAuth": []}],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "exam_id": {"type": "integer"},
                                    "answers": {"type": "array"}
                                }
                            }
                        }
                    }
                },
                "responses": {
                    "201": {"description": "Respostas submetidas"}
                }
            }
        },
        "/submissions/exam/{examId}/result/{userId}": {
            "get": {
                "tags": ["Submissions"],
                "summary": "Ver resultado de uma prova",
                "security": [{"bearerAuth": []}],
                "parameters": [
                    {"name": "examId", "in": "path", "required": true, "schema": {"type": "integer"}},
                    {"name": "userId", "in": "path", "required": true, "schema": {"type": "integer"}}
                ],
                "responses": {
                    "200": {"description": "Resultado da prova"}
                }
            }
        },
        "/submissions/exam/{examId}/user/{userId}": {
            "get": {
                "tags": ["Submissions"],
                "summary": "Ver respostas do usuário",
                "security": [{"bearerAuth": []}],
                "parameters": [
                    {"name": "examId", "in": "path", "required": true, "schema": {"type": "integer"}},
                    {"name": "userId", "in": "path", "required": true, "schema": {"type": "integer"}}
                ],
                "responses": {
                    "200": {"description": "Respostas do usuário"}
                }
            }
        },
        "/analytics/exam/{exam}": {
            "get": {
                "tags": ["Analytics"],
                "summary": "Estatísticas gerais de uma prova",
                "security": [{"bearerAuth": []}],
                "parameters": [
                    {"name": "exam", "in": "path", "required": true, "schema": {"type": "integer"}}
                ],
                "responses": {
                    "200": {"description": "Estatísticas"}
                }
            }
        },
        "/analytics/exam/{exam}/ranking": {
            "get": {
                "tags": ["Analytics"],
                "summary": "Ranking de alunos",
                "security": [{"bearerAuth": []}],
                "parameters": [
                    {"name": "exam", "in": "path", "required": true, "schema": {"type": "integer"}}
                ],
                "responses": {
                    "200": {"description": "Ranking"}
                }
            }
        },
        "/analytics/exam/{exam}/average": {
            "get": {
                "tags": ["Analytics"],
                "summary": "Média da turma",
                "security": [{"bearerAuth": []}],
                "parameters": [
                    {"name": "exam", "in": "path", "required": true, "schema": {"type": "integer"}}
                ],
                "responses": {
                    "200": {"description": "Média da turma"}
                }
            }
        },
        "/analytics/exam/{exam}/top": {
            "get": {
                "tags": ["Analytics"],
                "summary": "Melhor pontuação",
                "security": [{"bearerAuth": []}],
                "parameters": [
                    {"name": "exam", "in": "path", "required": true, "schema": {"type": "integer"}}
                ],
                "responses": {
                    "200": {"description": "Melhor pontuação"}
                }
            }
        }
    },
    "components": {
        "securitySchemes": {
            "bearerAuth": {
                "type": "http",
                "scheme": "bearer",
                "bearerFormat": "JWT"
            }
        }
    }
}